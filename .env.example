# Anthropic — required for /api/nexus/generate and TestPanel
# Copy this file to .env.local and fill in your key (never commit .env.local)
ANTHROPIC_API_KEY=

# Model used for Nexus enrichment. Defaults to claude-haiku-4-5-20251001 if not set.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Max tokens for the enrichment response (default: 4096)
ANTHROPIC_MAX_TOKENS=4096

# Hard timeout in ms for the Anthropic fetch call (default: 25000)
ANTHROPIC_TIMEOUT_MS=25000

# Supabase — optional in local dev, required for auth and sync in production
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
